	"config": {
		"PersonalDashboardDeveloperSetup": {
			"description": "Catch fewer errors for easier troubleshooting",
			"value": false
		},
		"PersonalDashboardSurveyLink": {
			"description": "External link to the Personal Dashboard feedback survey.",
			"value": null
		},
		"PersonalDashboardUserMenu": {
			"description": "Show a link to the Personal Dashboard in the user menu.",
			"value": true
		},
		"PersonalDashboardMinimumEdits": {
			"description": "The minimum number of edits required to show the menu link. This has no effect if `$wgPersonalDashboardUserMenu = false`.",
			"value": 0
		},
		"PersonalDashboardMaximumEdits": {
			"description": "The maximum number of edits required to show the menu link. This has no effect if `$wgPersonalDashboardUserMenu = false`",
			"value": 0
		},
		"PersonalDashboardBlueDot": {
			"description": "Show a blue dot inviting users to try out the dashboard. This has no effect if `$wgPersonalDashboardUserMenu = false` or a user does not meet the `$wgPersonalDashboardMinimum/MaximumEdits` threshold.",
			"value": true
		},
		"PersonalDashboardRiskyArticleEditsMlModel": {
			"description": "ML model used to filter edits",
			"value": "revertrisklanguageagnostic"
		},
		"PersonalDashboardRiskyArticleEditsEnabled": {
			"description": "Whether the risky article edits module is enabled",
			"value": true
		},
		"PersonalDashboardRiskyArticleEditsMinimumEditCount": {
			"description": "Minimum edit count required to view the risky article edits module",
			"value": 0
		},
		"PersonalDashboardActiveDiscussionsPages": {
			"description": "The pages were active discussions will be extracted from",
			"value": []
		}
	},
	"DatabaseVirtualDomains": [
		"virtual-dashboard"
	],
	"manifest_version": 2
}
