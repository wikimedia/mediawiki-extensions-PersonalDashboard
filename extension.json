{
	"name": "PersonalDashboard",
	"author": [
		"Jason Sherman",
		"[https://www.mediawiki.org/wiki/Growth/Team WMF Growth Team]"
	],
	"url": "https://www.mediawiki.org/wiki/Special:MyLanguage/Extension:PersonalDashboard",
	"descriptionmsg": "personal-dashboard-desc",
	"license-name": "GPL-3.0-or-later",
	"type": "other",
	"requires": {
		"MediaWiki": ">= 1.46",
		"extensions": {
			"CommunityConfiguration": "*"
		}
	},
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\PersonalDashboard\\": "src/"
	},
	"ServiceWiringFiles": [
		"ServiceWiring.php"
	],
	"SpecialPages": {
		"PersonalDashboard": {
			"class": "MediaWiki\\Extension\\PersonalDashboard\\Specials\\SpecialPersonalDashboard",
			"services": [
				"PersonalDashboardModuleRegistry",
				"UserOptionsManager",
				"StatsFactory"
			]
		}
	},
	"ConfigRegistry": {
		"PersonalDashboard": "MediaWiki\\Config\\GlobalVarConfig::newInstance"
	},
	"DefaultUserOptions": {
		"personaldashboard-eligible": false,
		"personaldashboard-visited": false,
		"personaldashboard-risky-articles-info": true
	},
	"HookHandlers": {
		"skintemplatenav-universal": {
			"class": "MediaWiki\\Extension\\PersonalDashboard\\HookHandler\\SkinTemplateNavigationUniversalHandler",
			"services": [
				"SpecialPageFactory",
				"UserOptionsManager",
				"UserEditTracker"
			]
		},
		"preferences": {
			"class": "MediaWiki\\Extension\\PersonalDashboard\\HookHandler\\GetPreferencesHandler"
		}
	},
	"Hooks": {
		"GetPreferences": "preferences",
		"SkinTemplateNavigation::Universal": "skintemplatenav-universal"
	},
	"MessagesDirs": {
		"PersonalDashboard": [
			"i18n/ext.personalDashboard.activeDiscussions",
			"i18n/ext.personalDashboard.common",
			"i18n/ext.personalDashboard.impact",
			"i18n/ext.personalDashboard.onboarding",
			"i18n/ext.personalDashboard.policiesGuidelines",
			"i18n/ext.personalDashboard.riskyArticleEdits",
			"i18n/ext.personalDashboard.riskyArticleEdits.mobile",
			"i18n/main"
		]
	},
	"ExtensionMessagesFiles": {
		"PersonalDashboardAlias": "PersonalDashboard.i18n.alias.php"
	},
	"ResourceModules": {
		"ext.personalDashboard.menuIcon": {
			"class": "MediaWiki\\ResourceLoader\\OOUIIconPackModule",
			"selectorWithVariant": ".vector-icon.mw-ui-icon-wikimedia-{name}-{variant}",
			"selectorWithoutVariant": ".vector-icon.mw-ui-icon-wikimedia-{name}, .minerva-icon--{name}",
			"useMaskImage": true,
			"icons": [
				"viewCompact"
			]
		},
		"ext.personalDashboard.blueDot": {
			"localBasePath": "resources/ext.personalDashboard.blueDot",
			"dependencies": [
				"mediawiki.pulsatingdot"
			],
			"packageFiles": [
				"index.js"
			],
			"styles": [
				"dots.less"
			]
		},
		"ext.personalDashboard.special.personalDashboard": {
			"localBasePath": "resources/ext.personalDashboard.special.personalDashboard",
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"codexComponents": [
				"CdxButton",
				"CdxDialog",
				"CdxIcon"
			],
			"packageFiles": [
				"init.js",
				"ModuleRoute.vue",
				{
					"name": "icons.json",
					"callback": "MediaWiki\\ResourceLoader\\CodexModule::getIcons",
					"callbackParam": [
						"cdxIconClose",
						"cdxIconNext",
						"cdxIconArrowPrevious"
					]
				}
			],
			"dependencies": [
				"vue",
				"ext.personalDashboard.common"
			]
		},
		"ext.personalDashboard.common": {
			"localBasePath": "resources/ext.personalDashboard.common",
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"codexComponents": [
				"CdxButton",
				"CdxDialog",
				"CdxIcon",
				"CdxInfoChip"
			],
			"dependencies": [
				"vue"
			],
			"messages": [
				"personal-dashboard-multi-step-dialog-progress",
				"personal-dashboard-multi-step-dialog-next-button",
				"personal-dashboard-multi-step-dialog-previous-button",
				"personal-dashboard-multi-step-dialog-got-it-button"
			],
			"packageFiles": [
				"index.js",
				"utils.js",
				"components/MultiStepDialog.vue",
				{
					"name": "icons.json",
					"callback": "MediaWiki\\ResourceLoader\\CodexModule::getIcons",
					"callbackParam": [
						"cdxIconClose",
						"cdxIconNext",
						"cdxIconPrevious"
					]
				}
			]
		},
		"ext.personalDashboard.onboarding": {
			"localBasePath": "resources/ext.personalDashboard.onboarding",
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"codexComponents": [
				"CdxCheckbox"
			],
			"dependencies": [
				"vue",
				"ext.personalDashboard.common"
			],
			"messages": [
				"personal-dashboard-onboarding-title",
				"personal-dashboard-onboarding-dont-show-again",
				"personal-dashboard-onboarding-get-started-button",
				"personal-dashboard-onboarding-step-1-body",
				"personal-dashboard-onboarding-step-1-alt",
				"personal-dashboard-onboarding-step-2-title",
				"personal-dashboard-onboarding-step-3-title",
				"personal-dashboard-onboarding-step-3-body",
				"personal-dashboard-onboarding-step-3-alt"
			],
			"packageFiles": [
				"init.js",
				"App.vue"
			]
		},
		"ext.personalDashboard.impact": {
			"localBasePath": "resources/ext.personalDashboard.impact",
			"remoteExtPath": "PersonalDashboard/resources/personalDashboard.impact",
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"codexComponents": [
				"CdxButton",
				"CdxIcon",
				"CdxPopover"
			],
			"dependencies": [
				"vue"
			],
			"messages": [
				"personal-dashboard-impact-thanks-sent",
				"personal-dashboard-impact-edits-reviewed",
				"personal-dashboard-impact-edits-reviewed-description",
				"personal-dashboard-impact-info-button"
			],
			"packageFiles": [
				"App.vue",
				{
					"name": "icons.json",
					"callback": "MediaWiki\\ResourceLoader\\CodexModule::getIcons",
					"callbackParam": [
						"cdxIconCheckAll",
						"cdxIconInfo",
						"cdxIconInfoFilled",
						"cdxIconUserTalk"
					]
				}
			]
		},
