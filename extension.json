						"cdxIconError",
						"cdxIconSuccess"
					]
				}
			]
		},
		"ext.personalDashboard.riskyArticleEdits": {
			"localBasePath": "resources/ext.personalDashboard.riskyArticleEdits",
			"remoteExtPath": "PersonalDashboard/resources/personalDashboard.riskyArticleEdits",
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"codexComponents": [
				"CdxButton",
